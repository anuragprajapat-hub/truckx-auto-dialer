{
  "manifest_version": 3,
  "name": "TruckX Auto Dialer",
  "description": "TruckX agent dialer extension for HubSpot-connected outbound calling.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/truckx-16.png",
    "32": "icons/truckx-32.png",
    "48": "icons/truckx-48.png",
    "128": "icons/truckx-128.png"
  },
  "action": {
    "default_title": "TruckX Auto Dialer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/truckx-16.png",
      "32": "icons/truckx-32.png",
      "48": "icons/truckx-48.png",
      "128": "icons/truckx-128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://truckx-auto-dialer.onrender.com/*",
    "https://app.hubspot.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.hubspot.com/*"],
      "js": ["hubspot-content.js"],
      "run_at": "document_idle"
    }
  ]
}
