# Server
PORT=4242
PUBLIC_BASE_URL=http://localhost:4242
APP_USERNAME=admin
APP_PASSWORD=

# Persistence
DATABASE_URL=
REQUIRE_PERSISTENT_STORAGE=false
POSTGRES_CONNECT_ATTEMPTS=12
POSTGRES_CONNECT_DELAY_MS=5000
# Optional alternative for a paid Render persistent disk:
# STORE_PATH=/opt/render/project/src/data/store.json
# FILE_STORE_PERSISTENT=true

# Data source: mock or hubspot
LEAD_SOURCE=mock
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PROP_CONSENT=dialer_consent
HUBSPOT_PROP_DNC=do_not_call
HUBSPOT_PROP_ATTEMPTS=dialer_attempts
HUBSPOT_PROP_LAST_OUTCOME=last_call_outcome
HUBSPOT_PROP_TIME_ZONE=time_zone
HUBSPOT_PROP_LEAD_STATUS=hs_lead_status
HUBSPOT_LEAD_STATUS_VALUES=follow_up:FOLLOWUP,new:NEW,connected:CONNECTED

# Voice provider: mock, twilio, or plivo
VOICE_PROVIDER=mock
CALLER_ID_NUMBER=+15551234567
CALLER_ID_NUMBERS=+15551234567,+15559876543
DEFAULT_AGENT_PHONE=+15557654321
VOICEMAIL_AUDIO_URL=

# Twilio starter adapter
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Plivo starter adapter
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_RING_TIMEOUT_SECONDS=25
PLIVO_MACHINE_DETECTION=hangup
PLIVO_MACHINE_DETECTION_TIME_MS=5000
AGENT_CONNECTION_MODE=browser
PLIVO_BROWSER_USERNAME=
PLIVO_BROWSER_PASSWORD=
PLIVO_BROWSER_DIAL_TARGET=truckx-agent@phone.plivo.com
PLIVO_APPLICATION_ID=

# Compliance defaults
DEFAULT_CALL_WINDOW_START=09:00
DEFAULT_CALL_WINDOW_END=18:00
MAX_ATTEMPTS_PER_LEAD=3
# Optional comma-separated allowlist. Leave blank to dial every otherwise safe HubSpot status.
CALLABLE_LEAD_STATUSES=
STRICT_CALLABLE_LEAD_STATUSES=false

# Optional email invitations
RESEND_API_KEY=
INVITE_FROM_EMAIL=TruckX Auto Dialer <dialer@truckx.com>
